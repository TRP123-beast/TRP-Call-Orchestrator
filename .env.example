SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROPERTIES_TABLE=listings
TRIAL_NUMBER=+11234567890

# Voice agent (Twilio Media Streams ↔ OpenAI Realtime API)
OPENAI_API_KEY=your-openai-api-key
# Public URL the voice agent is reachable at (Twilio fetches TwiML from here).
# In local dev, run an ngrok tunnel to port 5050 and paste the https URL.
SERVER_URL=https://your-ngrok-url.ngrok.app
# Realtime model: gpt-4o-realtime-preview (best) or gpt-4o-mini-realtime-preview (cheaper)
VOICE_MODEL=gpt-4o-mini-realtime-preview
# Realtime voice: ash, ballad, coral, sage, shimmer, verse
VOICE_ID=ash
# Optional default outbound test number for `pnpm run call:test`
# TEST_CALL_TO=+14165551234

# SMS / text messaging
SMS_PROVIDER=mock  # or 'twilio'
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890
# Test against Twilio without a purchased number: set TWILIO_TEST_MODE=true and provide
# your Twilio "Test Credentials". Uses the magic sender +15005550006 (override w/ TWILIO_TEST_FROM).
# TWILIO_TEST_MODE=true
# TEST_TWILIO_ACCOUNT_SID=your-test-sid
# TEST_TWILIO_AUTH_TOKEN=your-test-token
# Optional: number to send test messages to (defaults to TRIAL_NUMBER)
# TEST_SMS_TO=+15555550123
