SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROPERTIES_TABLE=listings
TRIAL_NUMBER=+11234567890

# LiveKit (voice agent – free/open source, no paid cloud required)
# Option A: Local/self-hosted server (recommended – no LiveKit Cloud cost)
LIVEKIT_SELF_HOSTED=true
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
OPENAI_API_KEY=your-openai-api-key
# OpenAI TTS voice: ash, ballad, coral, sage, shimmer, verse (self-hosted uses OpenAI TTS)
LIVEKIT_TTS_VOICE_ID=ash

# SMS / text messaging
SMS_PROVIDER=mock  # or 'twilio'
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890
# Test against Twilio without a purchased number: set TWILIO_TEST_MODE=true and provide
# your Twilio "Test Credentials". Uses the magic sender +15005550006 (override w/ TWILIO_TEST_FROM).
# TWILIO_TEST_MODE=true
# TEST_TWILIO_ACCOUNT_SID=your-test-sid
# TEST_TWILIO_AUTH_TOKEN=your-test-token
# Optional: number to send test messages to (defaults to TRIAL_NUMBER)
# TEST_SMS_TO=+15555550123
