SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROPERTIES_TABLE=listings
TRIAL_NUMBER=+11234567890

# LiveKit (voice agent – free/open source, no paid cloud required)
# Option A: Local/self-hosted server (recommended – no LiveKit Cloud cost)
LIVEKIT_SELF_HOSTED=true
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
OPENAI_API_KEY=your-openai-api-key
# OpenAI TTS voice: ash, ballad, coral, sage, shimmer, verse (self-hosted uses OpenAI TTS)
LIVEKIT_TTS_VOICE_ID=ash
