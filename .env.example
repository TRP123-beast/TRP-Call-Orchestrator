SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROPERTIES_TABLE=listings
TRIAL_NUMBER=+11234567890

# Forge model (self-hosted Qwen3-32B via vLLM, OpenAI-compatible) — used for ALL
# SMS/text understanding + replies. No OpenAI API cost for text.
FORGE_URL=http://66.179.10.109:8000/v1
FORGE_MODEL=trp-agent
FORGE_API_KEY=dummy
TRP_WRAPPER_URL=http://66.179.10.109:5000

# ── Chained voice pipeline (src/voice/pipeline.ts) ──
# Whisper (STT) — self-hosted on the GPU server, port 3000.
STT_SERVER_URL=http://66.179.10.109:3000
# Transcription endpoint + multipart field name. Defaults assume an OpenAI-
# compatible server; override if the Whisper server differs (e.g. /asr, /inference).
# STT_TRANSCRIBE_PATH=/v1/audio/transcriptions
# STT_FIELD_NAME=file
# STT_MODEL=whisper-1
# STT_RAW=false            # true → POST raw audio bytes instead of multipart
# Kokoro (TTS) — self-hosted, OpenAI-compatible, port 8880. Returns PCM 24kHz.
TTS_SERVER_URL=http://66.179.10.109:8880
TTS_MODEL=kokoro
TTS_VOICE=af_heart
# Voice-activity detection tuning (end-of-utterance after VAD_SILENCE_MS of quiet).
# VAD_SILENCE_MS=1500
# VAD_ENERGY_THRESHOLD=700
# VAD_MIN_UTTERANCE_MS=400
# VOICE_PORT=5050          # Fastify voice server port
# VOICE_ENABLED=false      # set on the dashboard process to NOT also start :5050

# Voice agent — public URL Twilio fetches TwiML / posts callbacks to.
# In local dev, run an ngrok tunnel to port 5050 and paste the https URL.
SERVER_URL=https://your-ngrok-url.ngrok.app

# Legacy OpenAI Realtime agent (src/voice/twilio-realtime-agent.ts, `pnpm voice:realtime`).
# The chained pipeline above does NOT use OpenAI — these are only for the Realtime variant.
OPENAI_API_KEY=your-openai-api-key
VOICE_MODEL=gpt-4o-mini-realtime-preview
VOICE_ID=ash
# Optional default outbound test number for `pnpm run call:test` / `call:outbound`
# TEST_CALL_TO=+14165551234
# Outbound calling system (src/voice/outbound-caller.ts)
# COMPANY_NAME=TRP
# AI_AGENT_NAME=Marcus
# No Response Branch retry cadence + how many direct attempts before brokerage escalation
# RETRY_DELAY_MINUTES=20
# MAX_CALL_ATTEMPTS=2

# SMS / text messaging
SMS_PROVIDER=mock  # or 'twilio'
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+1234567890
# Test against Twilio without a purchased number: set TWILIO_TEST_MODE=true and provide
# your Twilio "Test Credentials". Uses the magic sender +15005550006 (override w/ TWILIO_TEST_FROM).
# TWILIO_TEST_MODE=true
# TEST_TWILIO_ACCOUNT_SID=your-test-sid
# TEST_TWILIO_AUTH_TOKEN=your-test-token
# Optional: number to send test messages to (defaults to TRIAL_NUMBER)
# TEST_SMS_TO=+15555550123
